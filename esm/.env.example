# ⚡ Equilibrium ESM (JavaScript) Configuration
# Copy this file to .env and fill in your API keys
# Leave keys blank to use free/local defaults (Ollama, DuckDuckGo, in-memory queue)

# ━━━ LLM Providers (choose at least one, or use free Ollama) ━━━

# OpenAI (https://platform.openai.com/api-keys)
# Used for: high-quality content generation, code analysis
# Free tier: $5 credit
OPENAI_API_KEY=

# Anthropic (https://console.anthropic.com/)
# Used for: reasoning-heavy tasks, safety filtering
# Free tier: $5 credit
ANTHROPIC_API_KEY=

# Google Gemini (https://ai.google.dev/)
# Used for: fast, cheap completions
# Free tier: unlimited for gemini-1.5-flash
GEMINI_API_KEY=

# Ollama (local, free, no API key needed)
# Download: https://ollama.com
# Models: qwen2.5-coder:7b, llama2:7b, mistral:7b
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ━━━ Search Providers (fallback chain: Tavily → SerpAPI → Brave → DuckDuckGo free) ━━━

# Tavily Search (https://tavily.com) — $200/month free tier
# Used for: research queries, web search
TAVILY_API_KEY=

# SerpAPI (https://serpapi.com) — $100/month free tier
# Used for: web search with structured results
SERPAPI_API_KEY=

# Brave Search (https://api.search.brave.com) — $1/month free tier
# Used for: privacy-focused search
BRAVE_SEARCH_API_KEY=

# Note: DuckDuckGo fallback requires NO API key (keyless scraper)

# ━━━ Video & Media (Remotion, TTS) ━━━

# ElevenLabs TTS (https://elevenlabs.io) — 10k free characters/month
# Used for: natural voice synthesis in videos
ELEVENLABS_API_KEY=

# Replicate (https://replicate.com) — $10/month free tier
# Used for: image generation, video models
REPLICATE_API_KEY=

# ━━━ Queue & Cache (production: Redis; local fallback: in-memory ioredis mock) ━━━

# Redis URL for distributed task queue
# Production: redis://username:password@hostname:6379/0
# Local fallback (no env var needed): in-memory EventEmitter, JSON file persistence
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ━━━ Database (SQLite or similar) ━━━

# Database connection URL
# SQLite (local): file:./data/equilibrium.db
# PostgreSQL (cloud): postgresql://user:password@host/db
DATABASE_URL=file:./data/equilibrium.db

# ━━━ Security ━━━

# JWT Secret Key (for auth tokens, session management)
# Default: provided (safe for dev); CHANGE THIS IN PRODUCTION
# Generate new: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7

# ━━━ Logging ━━━

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ━━━ Feature Flags ━━━

# Enable SCAR (Sovereign Critical Action Record) — prevents recursive failures
ENABLE_SCAR=true

# Enable Observability traces to runs/ folder
ENABLE_TRACES=true

# ━━━ Remotion Video Rendering ━━━

# Remotion project root (where compositions are defined)
REMOTION_PROJECT_ROOT=./esm/engines/05_media

# Output folder for rendered videos
REMOTION_OUTPUT_DIR=./out/videos
